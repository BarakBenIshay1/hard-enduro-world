{
  "name": "hard-enduro-world",
  "version": "0.1.0",
  "private": true,
  "description": "Production-grade Hard Enduro World Championship knowledge base.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node --import tsx prisma/seed.ts",
    "connector:fim-calendar:dry-run": "node --import tsx scripts/fim-calendar-dry-run.ts",
    "connector:results-overall:dry-run": "node --import tsx scripts/results-overall-import.ts",
    "connector:stage-results:dry-run": "node --import tsx scripts/stage-results-import.ts",
    "test": "pnpm run test:data-quality && pnpm run test:scoring-components && pnpm run test:component-rollup && pnpm run test:admin-results && pnpm run test:admin-standings && pnpm run test:standing-publications && pnpm run test:regulations && pnpm run test:results-import && pnpm run test:stage-results-import && pnpm run test:auth && pnpm run test:admin-ui",
    "test:fim-calendar": "node --import tsx scripts/fim-calendar-dry-run-tests.ts",
    "test:results-import": "node --import tsx scripts/results-import-pipeline-tests.ts",
    "test:stage-results-import": "node --import tsx scripts/stage-results-import-pipeline-tests.ts",
    "test:admin-results": "node --import tsx scripts/admin-results-cms-tests.ts",
    "test:admin-standings": "node --import tsx scripts/admin-standings-workflow-tests.ts",
    "test:standing-publications": "node --import tsx scripts/standing-publication-tests.ts",
    "test:data-quality": "node --import tsx scripts/data-quality-tests.ts",
    "test:regulations": "node --import tsx scripts/regulations-workflow-tests.ts",
    "test:scoring-components": "node --import tsx scripts/scoring-component-foundation-tests.ts",
    "test:component-rollup": "node --import tsx scripts/component-points-rollup-tests.ts",
    "test:auth": "node --import tsx scripts/auth-flow-tests.ts",
    "test:admin-events": "node --import tsx scripts/admin-events-cms-tests.ts",
    "test:admin-riders": "node --import tsx scripts/admin-riders-cms-tests.ts",
    "test:admin-teams": "node --import tsx scripts/admin-teams-cms-tests.ts",
    "test:admin-manufacturers": "node --import tsx scripts/admin-manufacturers-cms-tests.ts",
    "test:admin-motorcycles": "node --import tsx scripts/admin-motorcycles-cms-tests.ts",
    "test:header": "node --import tsx scripts/header-responsive-tests.ts",
    "test:admin-ui": "node --import tsx scripts/admin-ui-regression-tests.ts",
    "test:e2e": "playwright test",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "@upstash/redis": "^1.34.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.0",
    "husky": "^9.1.7",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
