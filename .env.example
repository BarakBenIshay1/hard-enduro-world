# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=local
APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Database
# Local development uses Docker PostgreSQL.
# Production should use Supabase PostgreSQL connection strings.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://hard_enduro:hard_enduro@localhost:5432/hard_enduro_world?schema=public
DIRECT_DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis / Cache
# Local development can use Docker Redis.
# Production should use Upstash Redis.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Supabase
# Placeholders only. Do not commit real project URLs or keys.
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY enable browser/server auth.
# SUPABASE_SERVICE_ROLE_KEY is reserved for trusted server-side admin operations.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=hard-enduro-media

# -----------------------------------------------------------------------------
# YouTube Connector
# Placeholders only. Step 17 uses mock/demo data until a real key is configured.
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Automation / Cron
# Placeholders only. Cron jobs are not live yet.
# -----------------------------------------------------------------------------
CRON_SECRET=
AUTOMATION_ENABLED=false
AUTOMATION_DRY_RUN=true

# -----------------------------------------------------------------------------
# Official Events Connector
# Placeholder only. Supports JSON or iCalendar-style calendar payloads.
# -----------------------------------------------------------------------------
OFFICIAL_EVENTS_URL=

# -----------------------------------------------------------------------------
# Official Results Connector
# Placeholder only. Supports HTML, JSON, CSV/timing exports, and PDF metadata.
# -----------------------------------------------------------------------------
OFFICIAL_RESULTS_URL=

# -----------------------------------------------------------------------------
# Admin
# Supabase Auth is prepared. ADMIN_OWNER_EMAIL can promote one verified Supabase
# account to the owner role until full profile management is enabled.
# -----------------------------------------------------------------------------
ADMIN_PROTECTION_ENABLED=false
ADMIN_ALLOWED_EMAILS=
ADMIN_OWNER_EMAIL=barakbenishay1@gmail.com

# -----------------------------------------------------------------------------
# Maps / Weather
# Future placeholders. No external calls are enabled yet.
# -----------------------------------------------------------------------------
MAPS_API_KEY=
WEATHER_API_KEY=

# -----------------------------------------------------------------------------
# Future AI
# Future placeholders. No AI features are implemented yet.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
AI_FEATURES_ENABLED=false
